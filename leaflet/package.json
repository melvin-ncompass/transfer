{
  "name": "geospatial-visualization-dashboard",
  "version": "1.0.0",
  "description": "Professional geospatial data visualization dashboard with Leaflet, D3, and Deck.gl",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd server && npm run dev",
    "client": "cd client && npm run dev",
    "install:all": "npm install && cd server && npm install && cd ../client && npm install",
    "build": "cd client && npm run build",
    "start": "cd server && npm start"
  },
  "keywords": [
    "leaflet",
    "deckgl",
    "d3",
    "postgis",
    "postgresql",
    "geospatial"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "geotiff": "^2.1.4-beta.0"
  }
}
