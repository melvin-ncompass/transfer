{
  "name": "cxh-pulse-client",
  "author": "datakind",
  "licence": "MIT",
  "version": "1.6.0",
  "private": false,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "start": "vite preview",
    "build": "tsc && vite build",
    "lint": "eslint \"src/**/*.{js,jsx,ts,tsx}\"",
    "lint:fix": "eslint --fix \"src/**/*.{js,jsx,ts,tsx}\"",
    "lint:print": "npx eslint --print-config eslint.config.mjs > eslint-show-config.json",
    "fm:check": "prettier --check \"src/**/*.{js,jsx,ts,tsx}\"",
    "fm:fix": "prettier --write \"src/**/*.{js,jsx,ts,tsx}\"",
    "fix:all": "npm run lint:fix && npm run fm:fix",
    "clean": "rm -rf node_modules .next out dist build",
    "re:dev": "yarn clean && yarn install && yarn dev",
    "re:build": "yarn clean && yarn install && yarn build",
    "re:build-npm": "npm run clean && npm install && npm run build",
    "tsc:dev": "yarn dev & yarn tsc:watch",
    "tsc:watch": "tsc --noEmit --watch",
    "tsc:print": "npx tsc --showConfig"
  },
  "engines": {
    "node": ">=20"
  },
  "overrides": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-palm": {
      "react": "^19.1.0",
      "react-dom": "^19.1.0"
    },
    "react-redux": {
      "react": "^19.1.0",
      "react-dom": "^19.1.0"
    }
  },
  "packageManager": "yarn@1.22.22",
  "dependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@fontsource-variable/dm-sans": "^5.2.5",
    "@fontsource/barlow": "^5.2.5",
    "@iconify/react": "^5.2.1",
    "@mui/lab": "^7.0.0-beta.10",
    "@mui/material": "^7.3.5",
    "@mui/x-date-pickers": "^8.17.0",
    "@reduxjs/toolkit": "^2.9.0",
    "@types/leaflet": "^1.9.21",
    "apexcharts": "^4.5.0",
    "async-mutex": "^0.5.0",
    "axios": "^1.12.2",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.19",
    "es-toolkit": "^1.34.1",
    "html-to-image": "^1.11.13",
    "leaflet": "^1.9.4",
    "leaflet.heat": "^0.2.0",
    "lodash": "^4.17.21",
    "lucide-react": "^0.553.0",
    "minimal-shared": "^1.0.7",
    "notistack": "^3.0.2",
    "react": "^19.1.0",
    "react-apexcharts": "^1.7.0",
    "react-dom": "^19.1.0",
    "react-icons": "^5.5.0",
    "react-image-crop": "^11.0.10",
    "react-leaflet": "^5.0.0",
    "react-map-gl": "^8.1.0",
    "react-multi-date-picker": "^4.5.2",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.4.1",
    "simplebar-react": "^3.3.0",
    "styled-components": "^6.1.19",
    "tinycolor2": "^1.4.2",
    "zxcvbn": "^4.4.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@types/lodash": "^4.17.20",
    "@types/node": "^22.14.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.1",
    "@types/react-map-gl": "^6.1.7",
    "@types/tinycolor2": "^1.4.6",
    "@types/zxcvbn": "^4.4.5",
    "@typescript-eslint/parser": "^8.29.0",
    "@vitejs/plugin-react-swc": "^3.8.1",
    "eslint": "^9.23.0",
    "eslint-import-resolver-typescript": "^4.3.1",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-perfectionist": "^4.11.0",
    "eslint-plugin-react": "^7.37.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-unused-imports": "^4.1.4",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.29.0",
    "vite": "^6.2.5",
    "vite-plugin-checker": "^0.9.1"
  }
}
