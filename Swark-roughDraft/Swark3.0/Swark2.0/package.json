{
    "name": "swark2",
    "displayName": "Swark 2.0",
    "description": "Create architecture diagrams from code automatically using LLMs with support for both D2 and Eraser formats",
    "version": "2.0.0",
    "publisher": "swark",
    "icon": "assets/logo/swark-icon.png",
    "license": "SEE LICENSE IN LICENSE",
    "homepage": "https://swark.io",
    "bugs": {
        "url": "https://github.com/swark-io/swark/issues",
        "email": "contact@swark.io"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/swark-io/swark.git"
    },
    "engines": {
        "vscode": "^1.91.0"
    },
    "extensionDependencies": [
        "github.copilot"
    ],
    "categories": [
        "Programming Languages",
        "Machine Learning",
        "Visualization",
        "AI"
    ],
    "activationEvents": [],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "swark2.architecture",
                "title": "Swark 2.0: Create Architecture Diagram"
            },
            {
                "command": "swark2.chunkedArchitecture", 
                "title": "Swark 2.0: Create Architecture Diagram (Large Repositories)"
            }
        ],
        "configuration": {
            "title": "Swark 2.0",
            "properties": {
                "swark2.maxFiles": {
                    "type": "number",
                    "default": 1000,
                    "description": "Max number of files to read. The number of files read is also affected by the LLM max token limit."
                },
                "swark2.fileExtensions": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [
                        "py",
                        "js",
                        "jsx",
                        "ts",
                        "tsx",
                        "mjs",
                        "cjs",
                        "c",
                        "h",
                        "cpp",
                        "cc",
                        "cxx",
                        "hpp",
                        "java",
                        "cs",
                        "go",
                        "rb",
                        "php",
                        "rs",
                        "scala",
                        "swift",
                        "kt",
                        "kts",
                        "lua",
                        "dart"
                    ],
                    "description": "List of file extensions to include in search."
                },
                "swark2.excludePatterns": {
                    "type": "array",
                    "items": {
                        "type": "string"
                    },
                    "default": [
                        "**/.*",
                        "**/.*/*",
                        "**/node_modules/**"
                    ],
                    "description": "List of glob patterns to exclude from file search."
                },
                "swark2.languageModel": {
                    "type": "string",
                    "markdownDescription": "Language model to use for diagram generation.",
                    "default": "gpt-4o",
                    "enum": [
                        "gpt-4o",
                        "claude-3.5-sonnet",
                        "o1-ga",
                        "o3-mini",
                        "gemini-2.0-flash"
                    ],
                    "enumDescriptions": [
                        "GPT 4o",
                        "Claude 3.5 Sonnet",
                        "OpenAI o1",
                        "OpenAI o3-mini",
                        "Gemini 2.0 Flash"
                    ]
                },
                "swark2.defaultOutputFormat": {
                    "type": "string",
                    "markdownDescription": "Default output format for diagrams.",
                    "default": "both",
                    "enum": [
                        "d2",
                        "eraser",
                        "both"
                    ],
                    "enumDescriptions": [
                        "D2 format only",
                        "Eraser format only",
                        "Both D2 and Eraser formats"
                    ]
                },
                "swark2.fixD2Cycles": {
                    "type": "boolean",
                    "default": false,
                    "description": "(Deprecated - not needed for D2) Automatically fix cycles in the generated diagram to prevent rendering failures."
                },
                "swark2.chunkingThreshold": {
                    "type": "number",
                    "default": 0.8,
                    "minimum": 0.1,
                    "maximum": 1.0,
                    "description": "Percentage of token limit to trigger chunking (0.8 = 80%). Lower values chunk more aggressively."
                },
                "swark2.enableChunking": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable intelligent dependency-based chunking for large repositories."
                }
            }
        },
        "keybindings": [
            {
                "command": "swark2.architecture",
                "key": "ctrl+shift+r",
                "mac": "cmd+shift+r",
                "when": "editorTextFocus"
            },
            {
                "command": "swark2.chunkedArchitecture",
                "key": "ctrl+shift+alt+r",
                "mac": "cmd+shift+alt+r",
                "when": "editorTextFocus"
            }
        ]
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "pretest": "npm run compile && npm run lint",
        "lint": "eslint src --ext ts",
        "test": "vscode-test"
    },
    "devDependencies": {
        "@types/mocha": "^10.0.7",
        "@types/node": "20.x",
        "@types/pako": "^2.0.3",
        "@types/vscode": "^1.91.0",
        "@typescript-eslint/eslint-plugin": "^7.14.1",
        "@typescript-eslint/parser": "^7.11.0",
        "@vscode/test-cli": "^0.0.10",
        "@vscode/test-electron": "^2.4.0",
        "eslint": "^8.57.0",
        "typescript": "^5.4.5"
    },
    "dependencies": {
        "@vscode/extension-telemetry": "^0.9.7",
        "js-base64": "^3.7.7",
        "pako": "^2.1.0"
    }
}
