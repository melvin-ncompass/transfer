# Server
PORT=3001

# Google Gemini Connection
# Request a key from https://aistudio.google.com/
GOOGLE_API_KEY=YOUR_GEMINI_API_KEY

# PostgreSQL Database Configuration
DB_HOST=localhost
DB_PORT=5432

# Production Security Note: 
# MUST be a dedicated Read-Only PostgreSQL user to prevent DROP / DELETE operations.
DB_USER=mcp_readonly_user
DB_PASS=mcp_secure_password
DB_NAME=business_analytics_db
